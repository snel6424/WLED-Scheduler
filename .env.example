# Copy this file to .env and adjust as needed, or set these as real
# environment variables (e.g. in docker-compose.yml). Every value
# shown here is the application's own default; nothing here needs to
# be set unless you want something different.

# Path to the SQLite database file. The containing directory is
# created automatically if it doesn't exist.
DATABASE_PATH=data/scheduler.db

# How often (in seconds) the background scheduler checks for due
# schedules.
SCHEDULER_POLL_INTERVAL_SECONDS=30

# How often (in seconds) the background loop checks whether each
# device is reachable, to drive the online/offline status shown in
# the UI. This is an HTTP reachability check, not ICMP ping.
DEVICE_HEALTH_CHECK_INTERVAL_SECONDS=60

# Standard Python logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Host and port uvicorn binds to. 0.0.0.0 is correct for Docker;
# change HOST to 127.0.0.1 if you specifically want to restrict this
# to local-machine-only access outside a container.
HOST=0.0.0.0
PORT=8000
